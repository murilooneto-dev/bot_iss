# Copie este arquivo para .env e preencha os valores

# Caminho do banco SQLite (criado automaticamente se não existir)
DB_PATH=bot_iss.db

# Pasta onde os PDFs serão salvos
DOWNLOAD_DIR=downloads

# SMTP para envio de e-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail
EMAIL_FROM=seu-email@gmail.com

# true = sem janela do browser (servidor) | false = abre janela (debug)
HEADLESS=true

# URL do Sistema Fiscal (padrão: localhost)
FISCAL_SYSTEM_URL=http://localhost:3000
